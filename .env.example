# GEMINI_API_KEY: Required for PDF text extraction via Gemini.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# Qwen3 TTS (local, Apple Silicon / MLX). Defaults work with `bun start`.
# TTS_URL="http://127.0.0.1:8765"
# TTS_PORT="8765"
# Preferred model for stable multi-chunk tone (ICL + preview cache anchors):
# QWEN_TTS_MODEL="Qwen3-TTS-12Hz-0.6B-Base-8bit"
# Fallback if Base is missing: Qwen3-TTS-12Hz-0.6B-CustomVoice-8bit
# QWEN_TTS_VOICE="Vivian"
# QWEN_TTS_LANGUAGE="Auto"
# QWEN_TTS_TEMPERATURE="0.3"
# QWEN_TTS_INSTRUCT="Speak as a consistent, calm, neutral book narrator. Keep the same pitch, energy, emotion, and pace for every sentence."
# Idle timeout for each /tts call in ms. Leave unset/0 to wait until generation finishes.
# TTS_TIMEOUT_MS="0"
