{
  "name": "aura-reader",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "bun run scripts/start.ts",
    "start": "bun run scripts/start.ts",
    "start:tts": "cd qwen3-tts-apple-silicon && .venv/bin/python tts_server.py",
    "start:app": "bun run server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "electron": "bun run build && node scripts/ensure-electron.cjs && electron .",
    "electron:dev": "bun run build && node scripts/ensure-electron.cjs && NODE_ENV=production electron .",
    "dist:mac": "bun run build && node scripts/ensure-electron.cjs && electron-builder --mac --arm64",
    "clean": "rm -rf dist server.js release",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "epub2": "^3.0.2",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-lib": "^1.17.1",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "build": {
    "appId": "dev.aura.reader",
    "productName": "AuraReader",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dir",
        "dmg"
      ],
      "identity": null
    },
    "extraMetadata": {
      "main": "electron/main.cjs"
    }
  }
}
